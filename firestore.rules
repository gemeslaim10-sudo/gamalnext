rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ══════════════════════════════════════════════════════════════════
    // 🔧 Helper Functions
    // ══════════════════════════════════════════════════════════════════

    function isLoggedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isLoggedIn() && (
        request.auth.token.email == "montasrrm@gmail.com" ||
        request.auth.token.email == "gemeslaim10@gmail.com"
      );
    }

    function isOwner(userId) {
      return isLoggedIn() && request.auth.uid == userId;
    }

    // ══════════════════════════════════════════════════════════════════
    // 📝 Articles
    // ══════════════════════════════════════════════════════════════════
    match /articles/{articleId} {
      allow read: if true;
      allow create: if isLoggedIn() && 
                    request.resource.data.authorId == request.auth.uid &&
                    (isAdmin() || request.resource.data.status == 'pending');
      allow update: if isAdmin() || (isLoggedIn() && isOwner(resource.data.authorId) && request.resource.data.authorId == request.auth.uid && (isAdmin() || request.resource.data.status == resource.data.status));
      allow delete: if isAdmin() || isOwner(resource.data.authorId);
    }

    // ══════════════════════════════════════════════════════════════════
    // 📰 Posts (User Feed Posts)
    // ══════════════════════════════════════════════════════════════════
    match /posts/{postId} {
      allow read: if true;
      allow create: if isLoggedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin() || (isLoggedIn() && isOwner(resource.data.userId) && request.resource.data.userId == request.auth.uid);
      allow delete: if isAdmin() || isOwner(resource.data.userId);
    }

    // ══════════════════════════════════════════════════════════════════
    // ❤️ Likes
    // ══════════════════════════════════════════════════════════════════
    match /likes/{likeId} {
      allow read: if true;
      allow create: if isLoggedIn() && request.resource.data.userId == request.auth.uid;
      allow delete: if isLoggedIn() && isOwner(resource.data.userId);
    }

    // ══════════════════════════════════════════════════════════════════
    // 💬 Comments
    // ══════════════════════════════════════════════════════════════════
    match /comments/{commentId} {
      allow read: if true;
      allow create: if isLoggedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin() || (isLoggedIn() && isOwner(resource.data.userId) && request.resource.data.userId == request.auth.uid);
      allow delete: if isAdmin() || isOwner(resource.data.userId);
    }

    // ══════════════════════════════════════════════════════════════════
    // ⭐ Reviews
    // ══════════════════════════════════════════════════════════════════
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isLoggedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ══════════════════════════════════════════════════════════════════
    // 👤 Users
    // ══════════════════════════════════════════════════════════════════
    match /users/{userId} {
      allow read: if true;
      allow create: if isLoggedIn() && request.auth.uid == userId;
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isOwner(userId) || isAdmin();
    }

    // ══════════════════════════════════════════════════════════════════
    // 🔔 Notifications
    // ══════════════════════════════════════════════════════════════════
    match /notifications/{notifId} {
      allow read: if isLoggedIn() && (request.auth.uid == resource.data.recipientId || (resource.data.recipientId == 'ADMIN' && isAdmin()));
      allow create: if isLoggedIn() && request.resource.data.senderId == request.auth.uid;
      allow update: if isLoggedIn() && (request.auth.uid == resource.data.recipientId || (resource.data.recipientId == 'ADMIN' && isAdmin()));
      allow delete: if isAdmin();
    }

    // ══════════════════════════════════════════════════════════════════
    // 🌐 Site Content (Hero, Settings, Projects, Skills)
    // ══════════════════════════════════════════════════════════════════
    match /site_content/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ══════════════════════════════════════════════════════════════════
    // ⚙️ Settings (AI Config, etc.)
    // ══════════════════════════════════════════════════════════════════
    match /settings/{settingId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // ══════════════════════════════════════════════════════════════════
    // 📢 Ads
    // ══════════════════════════════════════════════════════════════════
    match /ads/{adId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ══════════════════════════════════════════════════════════════════
    // 🛠️ Tools
    // ══════════════════════════════════════════════════════════════════
    match /tools/{toolId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ══════════════════════════════════════════════════════════════════
    // 📞 Leads (AI Chat Captured Leads)
    // ══════════════════════════════════════════════════════════════════
    match /leads/{leadId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ══════════════════════════════════════════════════════════════════
    // 💬 Chat Sessions + Messages
    // ══════════════════════════════════════════════════════════════════
    match /chat_sessions/{sessionId} {
      function isSessionOwner(sid) {
        return isLoggedIn() && sid == 'session_' + request.auth.uid;
      }

      allow read: if isAdmin() || isSessionOwner(sessionId) || !sessionId.matches('^session_');
      allow create: if isAdmin() || isSessionOwner(sessionId) || !sessionId.matches('^session_');
      allow update: if isAdmin() || isSessionOwner(sessionId) || !sessionId.matches('^session_');
      allow delete: if isAdmin();

      match /messages/{messageId} {
        allow read, create: if isAdmin() || isSessionOwner(sessionId) || !sessionId.matches('^session_');
        allow delete: if isAdmin() || isSessionOwner(sessionId) || !sessionId.matches('^session_');
      }
    }

    // ══════════════════════════════════════════════════════════════════
    // 📜 User History (Tool Usage)
    // ══════════════════════════════════════════════════════════════════
    match /user_history/{historyId} {
      allow read: if isLoggedIn() && isOwner(resource.data.userId);
      allow create: if isLoggedIn() && request.resource.data.userId == request.auth.uid;
      allow delete: if isOwner(resource.data.userId);
    }

  }
}
